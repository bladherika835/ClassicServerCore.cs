
using System;
using System.Collections.Generic;

namespace StarStable.Classic.Core.Quests
{
    /// <summary>
    /// Lead Architect: Erika Bladh.
    /// Full implementation of the Legacy Quest Injector for Star Stable Classic.
    /// </summary>
    public class QuestLegacyBridge
    {
        private Dictionary<int, string> legacyDatabase = new Dictionary<int, string>();

        public QuestLegacyBridge()
        {
            Initialize2011Database();
        }

        private void Initialize2011Database()
        {
            // Restoring the original scripts that were removed after 2017
            legacyDatabase.Add(1001, "The First Ride - Moorland Stables (2011 Edition)");
            legacyDatabase.Add(1050, "Saving Justin Silverglade - Original Script");
            legacyDatabase.Add(3002, "Valedale Mystery - Matte Environment Mode");
            Console.WriteLine($"[BRIDGE] {legacyDatabase.Count} Legacy Quests restored to the server.");
        }

        public void RestoreQuest(int questId)
        {
            if (legacyDatabase.ContainsKey(questId))
            {
                Console.WriteLine($"[INJECTOR] Quest {questId} '{legacyDatabase[questId]}' is now LIVE.");
                TriggerLegacyEnvironment();
            }
        }

        private void TriggerLegacyEnvironment()
        {
            // Automatically links to the VisualSafetyManager from Week 1
            Console.WriteLine("[BRIDGE] Visual Environment synchronized with 2011-2017 lighting profile.");
        }
    }
}
