using System;
using StarStable.Classic.Core.Graphics;
using StarStable.Classic.Core.Quests;

namespace StarStable.Classic.Final
{
    /// <summary>
    /// Lead Architect: Erika Bladh.
    /// The Final Pitch: Full System Integration for Star Stable Classic Server.
    /// Bridges AI Reshape, Visual Safety, and Legacy Quests into one unified engine.
    /// </summary>
    public class ClassicServerFinal
    {
        private VisualSafetyManager _graphics;
        private QuestLegacyBridge _quests;
        
        public string EngineStatus { get; private set; } = "Ready for OG Community";

        public ClassicServerFinal()
        {
            // Initializing the 2011-2017 Legacy Environment
            _graphics = new VisualSafetyManager();
            _quests = new QuestLegacyBridge();
        }

        public void BootClassicServer()
        {
            Console.WriteLine("--- INITIALIZING STAR STABLE CLASSIC SERVER ---");
            
            // Step 1: Deploy Visual Safety (Photophobia Protection)
            _graphics.ApplySafetyProtocol();
            
            // Step 2: Inject AI-Reshape Logic (Optimized for Low RAM)
            Console.WriteLine("[AI] Reshape Engine: ACTIVE. Managing real-time luminance.");
            
            // Step 3: Load the 2011-2017 Narrative
            _quests.RestoreQuest(1001); // Loading 'The First Ride' 2011
            
            Console.WriteLine("--- SERVER STATUS: LIVE (MATTE 2011 MODE) ---");
        }
    }
}
